FROM python:3.11-slim

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

ARG BASE_COMMIT

RUN git clone https://github.com/pallets/flask.git /repo
WORKDIR /repo
RUN git checkout ${BASE_COMMIT}

# Install with async and dotenv extras, plus additional test dependencies
RUN pip install --no-cache-dir -e ".[async,dotenv]" asgiref greenlet pytest python-dotenv
COPY eval_script.sh /eval_script.sh
